{
  "manifest_version": 3,
  "name": "Ebook Screenshot Selector",
  "version": "1.0",
  "description": "Automatically filters and selects screenshots of ebook text on Google Photos for easy album grouping.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://photos.google.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scan Ebook Screenshots"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://photos.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
